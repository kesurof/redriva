# Variables d'environnement pour la production
# IMPORTANT: Ne pas commiter ce fichier avec des vraies valeurs !

# Configuration de l'application
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Base de données
DATABASE_URL=sqlite:///app/data/redriva.db

# Redis (File d'attente)
REDIS_URL=redis://redis:6379/0

# Real-Debrid API
REAL_DEBRID_API_URL=https://api.real-debrid.com/rest/1.0
REAL_DEBRID_CLIENT_ID=your_client_id_here
REAL_DEBRID_CLIENT_SECRET=your_client_secret_here

# Sécurité
SECRET_KEY=your_very_secure_secret_key_here_min_32_chars
JWT_SECRET_KEY=your_jwt_secret_key_here
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SMTP (pour les notifications par email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@yourdomain.com

# Monitoring (optionnel)
SENTRY_DSN=your_sentry_dsn_here

# Limites
MAX_UPLOAD_SIZE=100MB
RATE_LIMIT_PER_MINUTE=60
