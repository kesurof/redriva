# Configuration Real-Debrid - Redriva
# Basé sur l'architecture RDM (Real-Debrid Manager)

# URLs de base Real-Debrid (identiques RDM)
PUBLIC_BASE_URI="https://api.real-debrid.com/rest/1.0"
PUBLIC_BASE_AUTH_URI="https://api.real-debrid.com"

# Configuration Torrentio (pour future intégration)
PUBLIC_TORRENTIO_BASE_URI="https://torrentio.strem.fun"

# Configuration Redriva - Utilisez uniquement votre token personnel
REALDEBRID_API_TOKEN=""  # Votre token Real-Debrid personnel

# Configuration base de données
DATABASE_URL="sqlite:///./data/redriva.db"

# Configuration logging
LOG_LEVEL="INFO"

# Configuration serveur
HOST="0.0.0.0"
PORT=8000

# Configuration frontend
FRONTEND_URL="http://localhost:5174"

# Limites API (basées sur RDM)
# Real-Debrid API limits:
# - Max 1000 éléments par requête individuelle
# - Max 2500 éléments au total via pagination
MAX_LIMIT_PER_REQUEST=1000
MAX_TOTAL_LIMIT=2500

# Timeouts
API_TIMEOUT=30
HTTP_CLIENT_TIMEOUT=30

# User-Agent
USER_AGENT="Redriva/1.0"
