# Configuration d'exemple pour Redriva
# Copiez ce fichier vers .env et configurez vos valeurs

# === CONFIGURATION API ===
# URL de l'API backend (ajustez selon votre environnement)
VITE_API_URL=http://localhost:8000

# === CONFIGURATION DE DÉVELOPPEMENT ===
# Mode de développement (development, production)
NODE_ENV=development

# === SÉCURITÉ ===
# Ne jamais committer les vraies valeurs de production
# Utilisez des gestionnaires de secrets en production

# === REAL-DEBRID (si utilisé) ===
# Token API Real-Debrid (obtenez le vôtre sur real-debrid.com/apitoken)
# REAL_DEBRID_TOKEN=votre_token_ici

# === MONITORING (optionnel) ===
# PROMETHEUS_ENABLED=true
# LOG_LEVEL=info

# === CONFIGURATION LEGACY (compatibilité) ===
# Real-Debrid Configuration (ancien format)
# REAL_DEBRID_API_KEY=your_api_key_here

# Security (ancien format)
# SECURITY_SECRET_KEY=your_secret_key_here
# JWT_SECRET=your_jwt_secret_here

# Database (optionnel)
# DATABASE_URL=sqlite:///./data/redriva.db
