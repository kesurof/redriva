# Configuration d'exemple pour Redriva
# Copiez ce fichier vers .env et configurez vos valeurs

# === CONFIGURATION API ===
# URL de l'API backend (ajustez selon votre environnement)
VITE_API_URL=http://localhost:8080

# === CONFIGURATION PORTS ===
# Ports utilisés par l'application
BACKEND_PORT=8080
FRONTEND_PORT=5174

# === CONFIGURATION DE DÉVELOPPEMENT ===
# Mode de développement (development, production)
NODE_ENV=development

# === SÉCURITÉ ===
# Ne jamais committer les vraies valeurs de production
# Utilisez des gestionnaires de secrets en production
SECRET_KEY=your-super-secret-key-here
CORS_ORIGINS=http://localhost:5174

# === REAL-DEBRID (optionnel) ===
# Token API Real-Debrid (obtenez le vôtre sur real-debrid.com/apitoken)
# REAL_DEBRID_API_KEY=votre_token_ici

# === BASE DE DONNÉES ===
# SQLite par défaut (recommandé pour la plupart des cas)
DATABASE_URL=sqlite:///./data/redriva.db

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=logs/redriva.log

# === MONITORING (optionnel) ===
ENABLE_METRICS=true
# PROMETHEUS_ENABLED=true

# === MONITORING (optionnel) ===
ENABLE_METRICS=true
# PROMETHEUS_ENABLED=true

# === CONFIGURATION LEGACY (compatibilité) ===
# Anciens formats de configuration (rétrocompatibilité)
# REAL_DEBRID_TOKEN=votre_token_ici
# SECURITY_SECRET_KEY=your_secret_key_here
# JWT_SECRET=your_jwt_secret_here

# === DÉPLOIEMENT ===
# Variables pour le déploiement en production
# DOMAIN=your-domain.com
# EMAIL=admin@your-domain.com
# HTTPS_REDIRECT=true

# Database (optionnel)
# DATABASE_URL=sqlite:///./data/redriva.db
